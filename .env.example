PORT=3001
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@riskbusters.com
ADMIN_PASSWORD=demo123

# NODE_ENV controls which MongoDB is used when MONGODB_URI is not set:
#   development (default) → Atlas cloud URI
#   production            → local MongoDB (mongodb://localhost:27017/riskBuster)
NODE_ENV=development

# Override the auto-selected DB by setting this explicitly:
# MONGODB_URI=mongodb://localhost:27017/riskBuster

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your_smtp_user@riskbusters.co.in
SMTP_PASSWORD=your_smtp_app_password
CONTACT_RECEIVER_EMAIL=your_contact_email@riskbusters.co.in
