# ── MongoDB connection ────────────────────────────────────────────
# NODE_ENV controls which DB is used when MONGODB_URI is not set:
#   production  → mongodb://localhost:27017/riskBuster  (local)
#   development → mongodb+srv://...                     (Atlas cloud)
#
# Uncomment ONE of the lines below to force a specific DB regardless of NODE_ENV:
# MONGODB_URI=mongodb://localhost:27017/riskBuster
# MONGODB_URI=mongodb+srv://indiaProject:LEsbp5k9osyQcp6Q@indiaproject.1go0lry.mongodb.net/

